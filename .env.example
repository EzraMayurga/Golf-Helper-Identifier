# Frontend API URL (set to your Render backend URL in Vercel env vars)
VITE_API_URL=http://localhost:5000
# Optional alias — either VITE_API_URL or VITE_API_BASE works
VITE_API_BASE=http://localhost:5000
# WebSocket URL (optional — auto-derived from VITE_API_URL if omitted)
VITE_WS_URL=ws://localhost:5000
